<%= format(
      Translation.t('enterprise_email_admin_notification_html'),
      company_name: h(@enterprise_account.name),
      user_email: h(@user.email),
      payment_method: h(@enterprise_account.payment_method_label),
      plan: h(@enterprise_account.plan),
      paid_until: h(@enterprise_account.paid_until&.to_fs(:simple).presence || '—'),
      company_contact_information: simple_format(@enterprise_account.company_contact_information.presence || '(not provided)'),
      representative_contact_information: simple_format(@enterprise_account.representative_contact_information.presence || '(not provided)')
    ).html_safe %>
