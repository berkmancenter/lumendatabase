<article class="enterprise-account-status">
  <section class="body">
    <h3>Your Lumen Enterprise account isn't active yet</h3>

    <% case enterprise_account&.payment_method %>
    <% when 'credit_card' %>
      <% if pending_payment.present? %>
        <p class="enterprise-pending-payment">
          You have a card payment in progress for
          <strong><%= number_to_currency(pending_payment.amount_cents / 100.0) %></strong>.
          Your Pro access will unlock automatically as soon as Stripe confirms
          the payment.
        </p>
        <p>
          If you want to start over, cancel this pending payment first. You can
          choose a payment method again afterward.
        </p>
        <p>
          <%= button_to(
                'Cancel pending payment',
                enterprise_cancel_pending_payment_path,
                method: :post,
                data: { confirm: 'Cancel this pending card payment?' }
              ) %>
        </p>
      <% else %>
        <p>
          Your account is set up to pay by credit card. Your Pro access unlocks
          automatically as soon as Stripe confirms your card payment.
        </p>
        <p>
          If you haven't finished paying, start a new card payment below. If
          you think this is a mistake, contact us at
          <%= mail_to 'team@lumendatabase.org' %>.
        </p>
      <% end %>
    <% when 'invoice' %>
      <p>
        Your account is set up to be invoiced. Lumen will follow up with you about
        invoicing, and your Pro access unlocks once the invoice has been paid.
      </p>
      <p>
        Have a question about your invoice? Contact us at
        <%= mail_to 'team@lumendatabase.org' %>.
      </p>
    <% else %>
      <p>
        Your account isn't active yet. Contact us at
        <%= mail_to 'team@lumendatabase.org' %> to finish setting up your Lumen
        Enterprise plan.
      </p>
    <% end %>

    <% if enterprise_account&.paid_until.present? %>
      <p class="enterprise-plan-expired-on">
        Your most recent Pro subscription was paid through
        <strong><%= enterprise_account.paid_until.to_fs(:simple) %></strong>.
      </p>
    <% end %>
  </section>
</article>
