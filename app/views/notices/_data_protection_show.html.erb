<section class="notice-body">
  <% if notice.body.present? %>
    <h5 class="title"><%= notice.customizations&.fetch('body_field_label', nil) || 'Body' %></h5>
    <p class="body"><pre><%= redact_url_paths_unless_full_notice(@notice, notice.redacted(:body)) %></pre></p>
  <% end %>
</section>

<%= render 'works', notice: notice %>
